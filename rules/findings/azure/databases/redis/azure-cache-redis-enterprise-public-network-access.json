    ],
    "level": "medium",
    "tags": [],
    "rule": {
        "path": "az_redis_enterprise",
        "subPath": null,
        "selectCondition": {},
        "query": [
            {
                "filter": [
                    {
                        "conditions": [
                            [
                                "networking.publicNetworkAccess",
                                "ne",
								"Disabled"
                            ],
							[
								"eq",
                                "networking.privateEndpointConnections.id"
                            ]
                        ],
						"operator":"and"
                    }
                ]
            }
        ],
        "shouldExist": null,
        "returnObject": null,
        "removeIfNotExists": null
